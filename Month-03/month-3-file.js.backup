n1.next = n2;
n1.random = n2;
n2.random = n1;
const cloned = deepClone(n1);
console.log(cloned !== n1); // true (different objects)
console.log(cloned.val === n1.val); // true
console.log(cloned.random !== n1.random); // true (deep copy, not reference)

